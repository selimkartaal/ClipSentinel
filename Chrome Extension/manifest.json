{
  "manifest_version": 3,
  "name": "ClipSentinel",
  "version": "1.5.0",
  "description": "Clipboard DLP Control with Admin Settings",

  "permissions": ["storage", "clipboardRead", "tabs", "scripting"],

  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*",
    "<all_urls>"
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "ClipSentinel",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}